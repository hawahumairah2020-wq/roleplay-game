<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pokémon: BLACK SHADOW</title>
    <style>
        body { background-color: #000; color: white; font-family: 'Courier New', Courier, monospace; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; overflow: hidden; }
        #game-container { width: 600px; height: 400px; border: 4px solid #555; position: relative; background: #111; display: flex; flex-direction: column; justify-content: space-between; overflow: hidden;}
        
        /* Titlescreen */
        #title-screen { text-align: center; margin-top: 50px; }
        h1 { color: #f00; font-size: 40px; text-shadow: 2px 2px #500; }
        .blink { animation: blinker 1s linear infinite; color: #aaa; }
        @keyframes blinker { 50% { opacity: 0; } }

        /* Battle Scene */
        #battle-scene { display: none; padding: 20px; }
        .scene-top { display: flex; justify-content: space-between; margin-bottom: 20px; }
        .box { border: 2px solid white; padding: 10px; width: 40%; background: #222; }
        #player-stats { align-self: flex-end; }
        
        /* UI */
        #message-box { border: 2px solid white; padding: 10px; height: 60px; background: #000; }
        #actions { display: flex; gap: 10px; justify-content: center; padding: 10px; }
        button { padding: 10px; cursor: pointer; background: #333; color: white; border: 1px solid white; }
        button:hover { background: #500; }

        /* Gore/Scare */
        #gore-overlay { display: none; position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: red; z-index: 10; justify-content: center; align-items: center; flex-direction: column; animation: shake 0.5s infinite; }
        @keyframes shake { 0% { transform: translate(1px, 1px); } 50% { transform: translate(-1px, -1px); } 100% { transform: translate(1px, -1px); } }
    </style>
</head>
<body>

<div id="game-container">
    <!-- Title Screen -->
    <div id="title-screen">
        <h1>Pokémon: BLACK SHADOW</h1>
        <p>A Cursed Encounter</p>
        <p class="blink">Press ANY KEY to Start</p>
    </div>

    <!-- Battle Scene -->
    <div id="battle-scene">
        <div class="scene-top">
            <div class="box" id="enemy-stats">Ghost<br>HP: 100/100</div>
            <div class="box" id="player-stats">You<br>HP: 50/50</div>
        </div>
        <div id="message-box">A shadowy GHOST appears!</div>
        <div id="actions">
            <button onclick="playerTurn('fight')">FIGHT</button>
            <button onclick="playerTurn('run')">RUN</button>
        </div>
    </div>

    <!-- Gore Overlay -->
    <div id="gore-overlay">
        <h1 style="font-size: 50px; color: black;">D̶I̶E̶</h1>
        <p>Your soul belongs to me.</p>
    </div>
</div>

<script>
    let playerHP = 50;
    let enemyHP = 100;
    let gameActive = false;

    // Start Game
    window.addEventListener('keydown', () => {
        if (!gameActive) {
            document.getElementById('title-screen').style.display = 'none';
            document.getElementById('battle-scene').style.display = 'flex';
            gameActive = true;
        }
    });

    function updateStats() {
        document.getElementById('enemy-stats').innerHTML = `Ghost<br>HP: ${enemyHP}/100`;
        document.getElementById('player-stats').innerHTML = `You<br>HP: ${playerHP}/50`;
    }

    function playerTurn(action) {
        if (!gameActive) return;
        const msgBox = document.getElementById('message-box');

        if (action === 'run') {
            msgBox.innerText = "Can't escape!";
            setTimeout(() => enemyTurn(), 1000);
        } else {
            let damage = Math.floor(Math.random() * 20) + 10;
            enemyHP -= damage;
            msgBox.innerText = `You dealt ${damage} damage to GHOST!`;
            updateStats();
            
            if (enemyHP <= 0) {
                goodEnding();
            } else {
                setTimeout(() => enemyTurn(), 1000);
            }
        }
    }

    function enemyTurn() {
        const msgBox = document.getElementById('message-box');
        let damage = Math.floor(Math.random() * 15) + 5;
        playerHP -= damage;
        msgBox.innerText = `GHOST uses CURSE! You took ${damage} damage!`;
        updateStats();

        if (playerHP <= 0) {
            badEnding();
        }
    }

    function goodEnding() {
        gameActive = false;
        document.getElementById('message-box').innerText = "GHOST dissipated... You are safe... for now.";
        document.getElementById('actions').innerHTML = "<h2>You Win!</h2>";
    }

    function badEnding() {
        gameActive = false;
        document.getElementById('battle-scene').style.display = 'none';
        const overlay = document.getElementById('gore-overlay');
        overlay.style.display = 'flex';
        // Screech sound could be added here
        setTimeout(() => {
            overlay.innerHTML = "<h1 style='color:black;'>GAME OVER</h1><p>Restart to try again...</p>";
        }, 2000);
    }
</script>

</body>
</html>
